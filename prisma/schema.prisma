generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Plantation {
  id          String   @id @default(cuid())
  name        String
  district    String
  areaHa      Float
  trees       Int
  ndvi        Float    @default(0.0)
  status      String   @default("healthy")
  latitude    Float
  longitude   Float
  species     String   @default("Mixed")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  alerts      Alert[]
  carbonData  CarbonData[]
  fieldData   FieldData[]
}

model Alert {
  id            String     @id @default(cuid())
  plantationId  String
  plantation    Plantation @relation(fields: [plantationId], references: [id], onDelete: Cascade)
  ndviCurrent   Float
  ndviBaseline  Float
  ndviDrop      Float
  priority      String     @default("medium")
  status        String     @default("open")
  areaAffected  Float      @default(0)
  estimatedLoss Float      @default(0)
  detectedAt    DateTime   @default(now())
  resolvedAt    DateTime?
}

model CarbonData {
  id            String     @id @default(cuid())
  plantationId  String
  plantation    Plantation @relation(fields: [plantationId], references: [id], onDelete: Cascade)
  year          Int
  verifiedTco2e Float      @default(0)
  projectedTco2e Float     @default(0)
  agbTc         Float      @default(0)
  bgbTc         Float      @default(0)
  totalBiomass  Float      @default(0)
}

model FieldData {
  id          String     @id @default(cuid())
  plantationId String
  plantation  Plantation @relation(fields: [plantationId], references: [id], onDelete: Cascade)
  species     String
  dbh         Float      @default(0)
  height      Float      @default(0)
  gpsLat      Float
  gpsLon      Float
  notes       String?
  status      String     @default("pending")
  collectedAt DateTime   @default(now())
}

model AppEntry {
  id              String   @id @default(cuid())
  appSubmissionId String?
  division        String?
  region          String?
  district        String?
  upazila         String?
  unionName       String?  @map("union")
  village         String?
  locationType    String?
  seedlingSource  String?
  address         String?
  latitude        Float    @default(0)
  longitude       Float    @default(0)
  plantingDate    String?
  species         String?
  treeClass       String?
  count           Int      @default(0)
  ndvi            Float    @default(0)
  farmerName      String?
  farmerMobile    String?
  saaoName        String?
  saaoMobile      String?
  moName          String?
  moMobile        String?
  comments        String?
  block           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}